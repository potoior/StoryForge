# LLM 供应商：openai / claude / openai_compatible / mock
LLM_PROVIDER=mock

# OpenAI 配置
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Claude 配置
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 第三方兼容供应商（OpenAI 兼容接口）
# 适用于：DeepSeek、Moonshot、通义千问、硅基流动、Groq、Together 等
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# LLM 生成参数
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.7

# 内容长度要求（prompt 中要求的最少字数）
CHAPTER_MIN_WORDS=1000

# 服务端口
HOST=0.0.0.0
PORT=8000

# 输出目录
OUTPUT_DIR=output
